# ══════════════════════════════════════════════════════════════════
#  CV en 1 Minuto — Variables de Entorno
#  Copia este archivo a .env y completa los valores
#  ⚠️  Nunca subas .env a git (ya está en .gitignore)
# ══════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────
#  STRIPE — Suscripción Premium
#  Guía:
#  1. Crea una cuenta en https://dashboard.stripe.com
#  2. Ve a Payment Links → Crear nuevo link
#     - Precio: $4.99 USD, recurrente mensual
#     - URL de éxito: https://tudominio.com?stripe_paid=1
#     - URL de cancelación: https://tudominio.com
#  3. Copia la URL del Payment Link abajo
#  4. (Opcional) Copia tu clave pública para verificación client-side
# ──────────────────────────────────────────────────────────────────
VITE_STRIPE_PAYMENT_LINK=https://buy.stripe.com/REEMPLAZA_CON_TU_LINK
VITE_STRIPE_PUBLIC_KEY=pk_live_REEMPLAZA_CON_TU_CLAVE_PUBLICA

# Para pruebas (modo test de Stripe):
# VITE_STRIPE_PAYMENT_LINK=https://buy.stripe.com/test_XXXXX
# VITE_STRIPE_PUBLIC_KEY=pk_test_XXXXX

# ──────────────────────────────────────────────────────────────────
#  GROQ AI — Optimizador de CV
#  Obtén tu clave en https://console.groq.com
# ──────────────────────────────────────────────────────────────────
VITE_GROQ_API_KEY=gsk_REEMPLAZA_CON_TU_CLAVE_GROQ

# ══════════════════════════════════════════════════════════════════
#  PRODUCCIÓN
#  Para desplegar en Vercel/Netlify/etc:
#  Agrega estas variables en el panel de variables de entorno
#  del servicio (no uses el archivo .env en producción)
# ══════════════════════════════════════════════════════════════════
